# Copy this file to .env and fill in the values.

# MongoDB connection string. Leave unset to run in demo mode
# (an in-memory MongoDB is started automatically and re-seeded on every start).
# Free Atlas cluster: https://www.mongodb.com/cloud/atlas → M0 free tier
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/nest

# Google Gemini API key (free) — https://aistudio.google.com → "Get API key"
# GEMINI_API_KEY=

# Secret used to sign admin login tokens. Set any long random string.
JWT_SECRET=change-me-to-a-long-random-string

PORT=8000
